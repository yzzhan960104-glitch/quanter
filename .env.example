# ============ 数据湖（Epic 1）============
DATA_LAKE_PATH=data_lake/a_shares_daily.parquet
TUSHARE_TOKEN=
# tnskhdata 代理（tushare 兼容，10000 积分；非空则优先于此，回退直连 Tushare）
TNSKHDATA_TOKEN=

# JQData（分钟级，Epic 1）
# 用于分钟级 K 线与财务数据拉取；配额按 JQDATA_CONFIG 计数防超额。
JQDATA_USERNAME=
JQDATA_PASSWORD=

# ============ Celery（Epic 3）============
REDIS_URL=redis://localhost:6379/0
CELERY_EXPLORER_QUEUE=explorer

# ============ 宏观 + 钉钉（Epic 5）============
ALPHA_VANTAGE_API_KEY=
DINGTALK_WEBHOOK=
DINGTALK_SECRET=

# ============ QMT 实盘交易（Phase 1）============
# userdata_mini 完整路径（MiniQMT/XtItClient 启动登录后自动生成）
QMT_USERDATA_PATH=
QMT_ACCOUNT_ID=
QMT_SESSION_ID=123456
QMT_STRATEGY_NAME=quanter
# 风控挡板（dry_run 由前端按单控制，不在此；此为环境级总闸）
QMT_ALLOW_LIVE_TRADE=false
QMT_ORDER_MAX_AMOUNT=1000
QMT_ORDER_MAX_SHARES=100
QMT_SYMBOL_WHITELIST=510300.SH,511010.SH,510500.SH,159915.SZ
QMT_ENFORCE_SESSION=true
