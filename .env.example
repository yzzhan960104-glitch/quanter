# ============ 数据湖（Epic 1）============
DATA_LAKE_PATH=data_lake/a_shares_daily.parquet
# 直连 tushare（新token，2026-07-24 切换，积分充足直接走官方 API）
# 2026-07-24 废弃 tnskhdata 代理，_tushare_compat 简化为纯直连，不再读 TNSKHDATA_TOKEN。
TUSHARE_TOKEN=YOUR_TOKEN

# JQData（分钟级，Epic 1）
# 用于分钟级 K 线与财务数据拉取；配额按 JQDATA_CONFIG 计数防超额。
JQDATA_USERNAME=
JQDATA_PASSWORD=

# ============ Celery（Epic 3）============
REDIS_URL=redis://localhost:6379/0
CELERY_EXPLORER_QUEUE=explorer

# ============ 宏观 + 钉钉（Epic 5）============
ALPHA_VANTAGE_API_KEY=
DINGTALK_WEBHOOK=
DINGTALK_SECRET=

# ============ QMT 实盘交易（Phase 1）============
# userdata_mini 完整路径（MiniQMT/XtItClient 启动登录后自动生成）
QMT_USERDATA_PATH=
QMT_ACCOUNT_ID=
QMT_SESSION_ID=123456
QMT_STRATEGY_NAME=quanter
# 风控挡板（dry_run 由前端按单控制，不在此；此为环境级总闸）
QMT_ALLOW_LIVE_TRADE=false
QMT_ORDER_MAX_AMOUNT=1000
QMT_ORDER_MAX_SHARES=100
QMT_SYMBOL_WHITELIST=510300.SH,511010.SH,510500.SH,159915.SZ
QMT_ENFORCE_SESSION=true

# ============ 钉钉远程驱动 Claude 旁路桥（企业内部应用 Stream） ============
# 企业内部应用 Client ID（原 AppKey/SuiteKey）
DINGTALK_APP_KEY=
# Client Secret（原 AppSecret/SuiteSecret），本地填真值，绝不进 git
DINGTALK_APP_SECRET=
# 白名单 staffId，逗号分隔；全放行(bypassPermissions)模式下唯一身份闸
DINGTALK_ALLOWED_STAFF_IDS=
# claude CLI 可执行，默认走 PATH
CLAUDE_BIN=claude
# claude 工作目录，默认项目根
CLAUDE_WORKDIR=
# 单轮超时秒（claude 卡住 watchdog kill 阈值）
BRIDGE_ASK_TIMEOUT=120
# 空闲进程回收秒（常驻 claude 空闲超此值则 terminate）
BRIDGE_IDLE_TTL=900
# 单用户每分钟消息上限（防刷 + 钉钉频控）
BRIDGE_RATE_LIMIT_PER_MIN=10

# ============ 一期观测运营层（3 播报机器人 + 3 @查询常驻） ============
# 三个播报机器人的 dws 应用 robotCode（dws dev app robot submit 产出，见
# scripts/start_dingtalk_bots.md「观测层上线 SOP」Step 1；缺则 push_brief 跳过推送）。
TRADING_BOT_ROBOT_CODE=
DATA_BOT_ROBOT_CODE=
STRATEGY_BOT_ROBOT_CODE=
# 三个 @查询常驻（dws dev connect --channel claudecode）所需 unifiedAppId
# （建号后 dws dev app list / 开放平台控制台「统一应用ID」；一期交易/数据/策略三
#  机器人各自常驻，专业问答不再挤通用 yzzhanCli 机器人）。
TRADING_BOT_UNIFIED_APP_ID=
DATA_BOT_UNIFIED_APP_ID=
STRATEGY_BOT_UNIFIED_APP_ID=
# 钉钉运营群 openConversationId（4 机器人共用：行情既有 + 3 个观测层新机器人；
# 复用 BROADCAST_GROUP_ID 即 yzzhan量化群，不新建群）。
BROADCAST_GROUP_ID=
# 三个播报机器人每日触发时间（HH:MM，schtasks /ST；改时间改 .env + --register 幂等重建）
TRADING_BRIEF_TIME=15:30
STRATEGY_BRIEF_TIME=16:00
DATA_BRIEF_TIME=17:00

# ============ 二期 自动交易引擎（APScheduler cron + 风控参数）============
# 影子模式总闸：dry_run 只记账不真单；未跑满 TRADE_SHADOW_MIN_DAYS 日严禁切 live
# （Task11 上线 SOP 强制门）。live 走 QMT 通道。
AUTO_TRADE_MODE=dry_run
# 四个引擎 cron（APScheduler CronTrigger 标准 5 字段：分 时 日 月 周，1-5=周一至周五）
# 9:22 盘前挂单（集合竞价 9:20-9:25 窗口前下发限价单，避开 9:15-9:20 撤单高峰）
ENGINE_PRE_OPEN_CRON=22 9 * * 1-5
# 盘中止损巡检周期（Task8：cron `*/5 9-14` 5min → IntervalTrigger seconds=30）。
# Why interval：cron 最小粒度分钟，30s 必须 interval；时段约束（9:30-11:30/13:00-15:00）
# 下放给 stop_loss_monitor 内 calendar.is_intraday_session 兜底。
# ⚠️ 目标 30s，spec §10 限频实测后定终值——若 miniQMT 模拟盘连续
# get_quotes+query_stock_positions 撞柜台限流，上调 60s。原 ENGINE_STOPLOSS_CRON 已废弃。
ENGINE_STOPLOSS_INTERVAL_SECONDS=30
# 15:30 盘后对账（收盘后拉成交、对持仓、记 PnL，Task7 reconcile_job）
ENGINE_POST_CLOSE_CRON=30 15 * * 1-5
# 19:00 T 日盘后扫信号产 T+1 计划（Task6 时序修复：原 15:35 触发时 @18:00 增量采集
# 尚未落湖、@18:30 数据检查点② 未验通过，_eod 读到 T-1 数据算 T+1 计划 = 时序 bug。
# 挪 19:00 既等足数据落湖 + 检查点② 通过，又留足窗口在 T+1 09:22 pre_open 前完成扫盘 + 人审）
ENGINE_EOD_PLAN_CRON=0 19 * * 1-5
# —— 风控参数 ——
# 单标的仓位上限（占净值比例）；5% 分散，单股黑天鹅最多吃 5% 敞口
TRADE_POS_CAP=0.05
# 止损 ATR 倍数：止损价 = 颈线 - stop_atr_mult × ATR(N)（颈线法 v6 基线 2.0）
TRADE_STOP_ATR_MULT=2.0
# 止盈 H 倍数：止盈价 = 颈线 + tp_h_mult × H，H = 颈线 - 底部（颈线法 v6 基线 2.0）
TRADE_TP_H_MULT=2.0
# 总敞口上限（多标的累计占净值比例）；80% 留 20% 现金应对追加保证金/极端补仓
TRADE_MAX_TOTAL_EXPOSURE=0.80
# 海龟移动止损宽限天数：建仓后 N 日内只移不斩（给波动喘息空间，防开盘噪声扫损）
TRADE_STOPLOSS_GRACE_DAYS=5
# 移动止损步进系数：新止损 = max(旧止损, 现价 - STEP_ATR * ATR(N))
TRADE_STOPLOSS_STEP_ATR=0.1
# 止损硬底：移动止损不得低于建仓价 - FLOOR*ATR（防 ATR 极端压缩时止损过紧被秒扫）
TRADE_STOPLOSS_FLOOR=0.5
# 影子模式最少跑多少日才允许切 live（统计显著性门槛，样本不足易过拟合）
TRADE_SHADOW_MIN_DAYS=5
# 日内熔断：单日组合累计亏达 -3% 即清仓停机（Task6 circuit_breaker，防黑天鹅连环）
CIRCUIT_DAILY_LOSS_LIMIT=-0.03
# T-1 计划落盘目录（Task8 trading_plan 写次日挂单 JSON；.gitignore 已含 logs/）
TRADE_PLAN_DIR=logs/trading_plans
# eod_plan 扫信号的总资金（仓位整手预算基准；engine._eod 读 TRADE_CAPITAL 传 eod_plan）
TRADE_CAPITAL=1000000
